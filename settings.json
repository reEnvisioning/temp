    "font": {
      "family": "Monospace",
      "size": 10
    }
  },
  "modules": {
    "bar": true,
    "notifications": true,
    "clipboard": true,
    "launcher": true
  },
  "launcherProviders": {
    "app": true,
    "shell": true,
    "terminal": true,
    "ssh": true,
    "theme": true,
    "wallpaper": true,
    "system": true,
    "share": true,
    "emoji": true,
    "calc": true
  },
  "providerPrefixes": {
    "app": "",
    "shell": "\u003e ",
    "terminal": "\u003e\u003e ",
    "ssh": "ssh ",
    "theme": "#",
    "wallpaper": "$",
    "system": "@",
    "share": "^",
    "emoji": ": ",
    "calc": "= "
